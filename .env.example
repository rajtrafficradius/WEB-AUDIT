DJANGO_SETTINGS_MODULE=app.settings
DJANGO_LOAD_DOTENV=true
DJANGO_ENV=development
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-at-least-50-random-characters
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000
DJANGO_TIME_ZONE=Australia/Melbourne
DATABASE_URL=postgresql://seo_studio:seo_studio@postgres:5432/seo_studio
DB_CONN_MAX_AGE=60
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/2
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_VISIBILITY_TIMEOUT=14400
STAGE_HEARTBEAT_TIMEOUT_SECONDS=300
STAGE_STALE_SCAN_INTERVAL_SECONDS=60
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SECURE_SSL_REDIRECT=false
SECURE_HSTS_SECONDS=0

# Private object storage. Keep buckets private; downloads are authorized by Django.
OBJECT_STORAGE_ENABLED=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=auto
AWS_S3_ADDRESSING_STYLE=path
AWS_S3_VERIFY=true
AWS_QUERYSTRING_EXPIRE=300
OBJECT_STORAGE_PREFIX=private/objects
OBJECT_STORAGE_SSE=AES256
OBJECT_STORAGE_KMS_KEY_ID=

# Comma-separated key-id:urlsafe-base64-encoded-32-byte-key values.
CREDENTIAL_ENCRYPTION_KEYS=
CREDENTIAL_ENCRYPTION_ACTIVE_KEY=

# Integrations remain explicitly unavailable when blank.
OPENAI_API_KEY=
OPENAI_STRATEGY_MODEL=gpt-5.6-sol
OPENAI_EXTRACTION_MODEL=gpt-5.6-luna
OPENAI_INTAKE_GENERATION_ENABLED=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
PAGESPEED_API_KEY=
SEMRUSH_API_KEY=

# Observability. Never include credential values in log fields.
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=INFO
SENTRY_DSN=

# Deployed environments must override at least DJANGO_ENV, secret/host/origin values,
# PostgreSQL, Redis, private object storage, encryption keys, and secure TLS settings.
# Staging and production must never share databases, Redis namespaces, buckets, or keys.

